{
  "name": "git-crypt-vscode",
  "displayName": "git-crypt Diff",
  "description": "Makes git-crypt repositories work in the Source Control panel",
  "version": "2.0.0",
  "publisher": "j-256",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j-256/git-crypt-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "git-crypt",
    "encrypted",
    "scm"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "preversion": "[ \"$(git branch --show-current)\" = main ] || { echo 'Error: npm version must be run on main'; exit 1; } && npm run build && npm test",
    "postversion": "git push origin main v$npm_package_version",
    "retag": "git tag -f v$npm_package_version && git push origin v$npm_package_version --force",
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "node --import tsx --test test/*.test.ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
