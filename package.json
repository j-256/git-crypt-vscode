{
  "name": "git-crypt-vscode",
  "displayName": "git-crypt Diff",
  "description": "View diffs of git-crypt encrypted files in VSCode",
  "version": "1.0.1",
  "publisher": "j-256",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/j-256/git-crypt-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "git-crypt",
    "diff",
    "encrypted",
    "scm",
    "textconv"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitCrypt.showDiff",
        "title": "Git Crypt: Show Diff",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "scm/resourceState/context": [
        {
          "command": "gitCrypt.showDiff",
          "when": "scmProvider == git",
          "group": "inline"
        },
        {
          "command": "gitCrypt.showDiff",
          "when": "scmProvider == git"
        }
      ],
      "commandPalette": [
        {
          "command": "gitCrypt.showDiff"
        }
      ]
    }
  },
  "scripts": {
    "preversion": "npm run build && npm test",
    "postversion": "git push origin main v$npm_package_version && npm run release",
    "release": "npm run package && gh release create v$npm_package_version git-crypt-vscode-$npm_package_version.vsix --title v$npm_package_version --generate-notes",
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "node --import tsx --test test/*.test.ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
